---
import config from "@config/config.json";
import { SEO as Seo } from "astro-seo";

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  noindex?: boolean;
}

const { title, meta_title, description, noindex } = Astro.props;
const pageTitle = meta_title ?? title ?? config.site.title;
const pageDescription = description ?? config.metadata.meta_description;

const canonicalUrl = new URL(
  Astro.url.pathname,
  config.site.base_url,
).toString();

const ogImage = new URL("/og.jpg", config.site.base_url).toString();
const twitterImage = new URL("/og.png", config.site.base_url).toString();
---

<Seo
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  openGraph={{
    basic: {
      title: pageTitle,
      type: "website",
      image: ogImage,
      url: canonicalUrl,
    },
    optional: {
      description: pageDescription,
    },
  }}
  twitter={{
    title: pageTitle,
    description: pageDescription,
    image: twitterImage,
    card: "summary_large_image",
    creator: "@n10nce",
    site: "@n10nce",
    imageAlt: pageTitle,
  }}
  charset="utf-8"
  extend={{
    link: [{ rel: "icon", type: "image/svg+xml", href: config.site.favicon }],
    meta: [
      { name: "author", content: config.metadata.meta_author },
      {
        name: "viewport",
        content: "width=device-width, initial-scale=1, maximum-scale=5",
      },
      { name: "generator", content: Astro.generator },
      {
        name: "theme-color",
        media: "(prefers-color-scheme: dark)",
        content: "#000000",
      },
      ...(noindex ? [{ name: "robots", content: "noindex, nofollow" }] : []),
    ],
  }}
/>
